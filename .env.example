# App
APP_NAME=PAIOS
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/v1
FRONTEND_URL=http://localhost:5173

# Security
JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
POSTGRES_USER=paios
POSTGRES_PASSWORD=paios
POSTGRES_DB=paios
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://paios:paios@postgres:5432/paios

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=PAIOS
OPENROUTER_SITE_URL=http://localhost:5173

# Optional search fallbacks
TAVILY_API_KEY=
SERPAPI_KEY=

# Runtime
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
